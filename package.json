{
  "name": "@shawnstack/quickforge",
  "version": "1.5.3",
  "description": "AI chat application with Agent access modes for local workspace tools. React + Vite + Tailwind CSS frontend, local Node.js storage server.",
  "keywords": [
    "ai",
    "chat",
    "llm",
    "claude",
    "openai",
    "anthropic",
    "litellm",
    "react",
    "vite",
    "tailwindcss",
    "yolo",
    "workspace",
    "tools"
  ],
  "author": "shawn <1524587436@qq.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shawnstack/quickforge.git"
  },
  "bugs": {
    "url": "https://github.com/shawnstack/quickforge/issues"
  },
  "homepage": "https://github.com/shawnstack/quickforge#readme",
  "type": "module",
  "main": "./server/public-api.mjs",
  "bin": {
    "quickforge": "bin/quickforge.mjs",
    "qf": "bin/quickforge.mjs"
  },
  "files": [
    "bin",
    "server",
    "skills",
    "plugins",
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "dev": "node server/index.mjs --dev",
    "dev:web": "vite --host 127.0.0.1 --port 5176 --strictPort",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "desktop:dev": "electron desktop/electron-main.mjs",
    "desktop:build": "npm run build && electron-builder --config desktop/electron-builder.config.cjs",
    "desktop:build:win": "npm run build && electron-builder --config desktop/electron-builder.config.cjs --win",
    "desktop:build:mac": "npm run build && electron-builder --config desktop/electron-builder.config.cjs --mac",
    "desktop:build:linux": "npm run build && electron-builder --config desktop/electron-builder.config.cjs --linux",
    "desktop:build:all": "npm run build && electron-builder --config desktop/electron-builder.config.cjs --win --mac --linux",
    "release:patch:prepare": "node scripts/prepare-patch-release.cjs",
    "start": "node server/index.mjs",
    "preview": "node server/index.mjs"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.29.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@earendil-works/pi-agent-core": "^0.75.3",
    "@earendil-works/pi-ai": "^0.75.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vscode/ripgrep": "^1.18.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@earendil-works/pi-web-ui": "^0.75.3",
    "@eslint/js": "^10.0.1",
    "@mariozechner/mini-lit": "^0.2.1",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "lit": "^3.3.2",
    "lucide-react": "^1.11.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.8"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0"
  }
}
